# SendGrid (transactional lead email)
SENDGRID_FROM=no-reply@oaksdisposal.com
SENDGRID_KEY=your-sendgrid-api-key
SENDGRID_TO=info@oaksdisposal.com

# MySQL (lead persistence)
DB_HOST=localhost
DB_PORT=3306
DB_USER=oaks
DB_PASSWORD=change-me
DB_DB=oaks_leads

# Mailchimp (audience sync)
# MC_DC is derived from the API key suffix if omitted (e.g. key ends in "-us14")
MC_API_KEY=your-mailchimp-api-key
MC_LIST_ID=f31112e9ba
MC_DC=us14
MC_TAG=OaksDisposal

# Dashboard (Microsoft SSO at /dashboard)
AUTH_URL=https://oaksdisposal.com
AUTH_SECRET=generate-a-random-secret-at-least-32-chars
AUTH_MICROSOFT_ENTRA_ID_ID=azure-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=azure-client-secret
# AUTH_MICROSOFT_ENTRA_ID_TENANT=common  # optional, default "common"
# AUTH_ALLOWED_DOMAINS=oaksinc.com,komarketingco.com,gravesbros.com  # optional, these are defaults
